{
  "name": "@pokujs/vue",
  "version": "1.2.1",
  "private": false,
  "description": "Vue testing helpers and Poku plugin for DOM-backed component tests.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    },
    "./vue-testing": {
      "types": "./dist/vue-testing.d.ts",
      "import": "./dist/vue-testing.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.x.x",
    "bun": ">=1.x.x",
    "deno": ">=2.x.x",
    "typescript": ">=6.x.x"
  },
  "scripts": {
    "test": "npm run test:happy && npm run test:jsdom",
    "test:sfc:bundle": "vite build --config tests/sfc/vite.config.ts",
    "test:happy": "cross-env POKU_VUE_TEST_DOM=happy-dom node --import=tsx ./node_modules/poku/lib/bin/index.js tests --showLogs",
    "test:jsdom": "cross-env POKU_VUE_TEST_DOM=jsdom node --import=tsx ./node_modules/poku/lib/bin/index.js tests --showLogs",
    "test:bun": "cross-env POKU_VUE_TEST_DOM=happy-dom bun ./node_modules/poku/lib/bin/index.js tests --showLogs && cross-env POKU_VUE_TEST_DOM=jsdom bun ./node_modules/poku/lib/bin/index.js tests --showLogs",
    "test:deno": "cross-env POKU_VUE_TEST_DOM=happy-dom deno run -A npm:poku tests --showLogs",
    "clean": "rimraf dist",
    "build": "tsup src/index.ts src/plugin.ts src/vue-testing.ts src/dom-setup-happy.ts src/dom-setup-jsdom.ts src/vue-sfc-loader-hooks.ts --format esm --dts --target node20 --sourcemap --clean --tsconfig tsconfig.tsup.json --external @vue/compiler-sfc --external esbuild",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "npm run typecheck",
    "check": "npm run typecheck && npm run test:sfc:bundle && npm test",
    "prepack": "npm run build"
  },
  "keywords": [
    "poku",
    "vue",
    "testing",
    "testing-library",
    "happy-dom",
    "jsdom"
  ],
  "author": "Lojhan",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pokujs/vue.git"
  },
  "homepage": "https://github.com/pokujs/vue#readme",
  "bugs": {
    "url": "https://github.com/pokujs/vue/issues"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@pokujs/dom": "^1.0.1",
    "@testing-library/dom": "^10.4.1",
    "@vue/compiler-sfc": "^3.5.22",
    "esbuild": "^0.25.4"
  },
  "peerDependencies": {
    "@happy-dom/global-registrator": ">=20",
    "happy-dom": ">=20",
    "jsdom": ">=22",
    "poku": ">=4.1.0",
    "vue": ">=3.4"
  },
  "peerDependenciesMeta": {
    "@happy-dom/global-registrator": {
      "optional": true
    },
    "happy-dom": {
      "optional": true
    },
    "jsdom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@happy-dom/global-registrator": "^20.8.9",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.0",
    "cross-env": "^10.1.0",
    "happy-dom": "^20.8.9",
    "jsdom": "^26.1.0",
    "poku": "4.2.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^7.3.1",
    "vue": "^3.5.22"
  }
}
